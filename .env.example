# Local-only secrets for citation fetching.
SEMANTIC_SCHOLAR_API_KEY=replace_with_your_semantic_scholar_key

# Semantic Scholar approves this key at 1 request/second cumulative across endpoints.
# Keep this above 1.0 to stay comfortably below the limit.
SEMANTIC_SCHOLAR_MIN_INTERVAL_SECONDS=1.25

# Optional, for higher GitHub API limits when fetching stars locally.
# GITHUB_TOKEN=ghp_xxx
